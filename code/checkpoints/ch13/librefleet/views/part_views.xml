<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_librefleet_part_list" model="ir.ui.view">
        <field name="name">librefleet.part.list</field>
        <field name="model">librefleet.part</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="standard_cost"/>
                <field name="list_price"/>
            </list>
        </field>
    </record>

    <record id="action_librefleet_part" model="ir.actions.act_window">
        <field name="name">Parts</field>
        <field name="res_model">librefleet.part</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
